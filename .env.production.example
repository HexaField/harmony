# Harmony — Production Environment
# Copy to .env.production and fill in real values.
# NEVER commit this file with real values.

# ─── Cloudflare ─────────────────────────────────────────────
CF_ACCOUNT_ID=REPLACE_ME
CF_API_TOKEN=REPLACE_ME

# ─── Discord OAuth2 ─────────────────────────────────────────
DISCORD_CLIENT_ID=REPLACE_ME
DISCORD_CLIENT_SECRET=REPLACE_ME
DISCORD_REDIRECT_URI=https://harmony.chat/api/oauth/discord/callback

# ─── Portal Worker ──────────────────────────────────────────
PORTAL_URL=https://portal.harmony.chat

# ─── Cloud Worker ───────────────────────────────────────────
CLOUD_URL=https://cloud.harmony.chat

# ─── Stripe (live mode) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_ID_VOICE=price_REPLACE_ME
STRIPE_PRICE_ID_MEDIA=price_REPLACE_ME
STRIPE_PRICE_ID_WS=price_REPLACE_ME

# ─── UI App (Vite) ──────────────────────────────────────────
VITE_DEFAULT_SERVER_URL=wss://cloud.harmony.chat
VITE_PORTAL_URL=https://portal.harmony.chat
VITE_CLOUD_API_URL=https://cloud.harmony.chat
