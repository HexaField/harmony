# Harmony Docker Configuration
# Copy this file to .env and fill in values

# Server port (default: 4000)
HARMONY_PORT=4000

# UI port (default: 8080)
HARMONY_UI_PORT=8080

# Portal URL (default: public portal)
HARMONY_PORTAL_URL=https://portal.harmony.chat

# Discord bot token (only needed with --profile with-bot)
DISCORD_TOKEN=
