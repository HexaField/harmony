# Harmony — Local Development Environment
# Copy to .env and fill in your values.
# .env and .env.local are gitignored.

# ─── Discord OAuth2 (Portal / Cloud) ───────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/oauth/discord/callback

# ─── Portal ────────────────────────────────────────────────
PORT=3000

# ─── Server Runtime ────────────────────────────────────────
# These are also settable via harmony.config.yaml
HARMONY_PORT=4000
HARMONY_HOST=0.0.0.0

# ─── UI App (Vite — must be prefixed VITE_) ────────────────
VITE_DEFAULT_SERVER_URL=ws://localhost:4000
VITE_PORTAL_URL=http://localhost:3000
# VITE_CLOUD_API_URL=http://localhost:3001
